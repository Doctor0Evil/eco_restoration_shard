# Rust toolchain environment configuration
# Source this file before building to use the /mnt/oss-based Rust toolchain

export RUSTUP_HOME=/mnt/oss/rustup
export CARGO_HOME=/mnt/oss/cargo
export PATH="$CARGO_HOME/bin:$PATH"

# Verify toolchain is available
if ! command -v rustc &> /dev/null; then
    echo "ERROR: rustc not found. Make sure Rust is installed at $RUSTUP_HOME"
    echo "Run: rustup default stable"
    return 1
fi

echo "Rust toolchain configured:"
echo "  rustc: $(rustc --version)"
echo "  cargo: $(cargo --version)"
echo "  RUSTUP_HOME: $RUSTUP_HOME"
echo "  CARGO_HOME: $CARGO_HOME"
