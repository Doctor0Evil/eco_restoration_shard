alnversion 1.0
schema     ecosafety.corridors.v2

particle corridors.ecosafety.v2
  field varid        string
  field safe         f64
  field gold         f64
  field hard         f64
  field weight       f64
  field lyapchannel  string
  field mandatory    bool
end

-- Carbon balance per operational cycle (net kg CO2e / kg pollutant removed)
CARBON.NETINTENSITY, -0.30, -0.05, 0.05, 0.20, "carbon", true
-- Habitat connectivity index (dimensionless, higher is better)
BIODIV.CONNECTIVITY, 0.60, 0.80, 1.00, 0.10, "biodiversity", true
-- Structural complexity (e.g., log of microhabitat density)
BIODIV.STRUCTCOMPLEX, 1.40, 1.70, 2.00, 0.10, "biodiversity", true
-- Colonization potential (0–1)
BIODIV.COLONIZATION, 0.50, 0.75, 1.00, 0.10, "biodiversity", true
